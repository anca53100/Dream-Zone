+        <a href="/"><button type="button">✕</button></a>
+      </div>
+    </form>
+  </div>
+
+  <main class="main">
+
+    <!-- DESTACADOS -->
+    <div th:if="${activeCat == 'Todos' and busqueda == null}">
+      <div class="section-title">Destacado</div>

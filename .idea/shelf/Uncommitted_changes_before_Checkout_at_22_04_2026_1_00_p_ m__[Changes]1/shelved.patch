+              <rect x="3" y="3" width="18" height="18" rx="2"/>
+              <circle cx="8.5" cy="8.5" r="1.5"/>
+              <path d="M21 15l-5-5L5 21"/>
+            </svg>
+            <div class="p-badge" th:if="${p.badge != null}" th:text="${p.badge}">NEW</div>
+          </div>
+          <div class="p-info">
+            <div class="p-name" th:text="${p.nombre}">Nombre</div>
+            <div class="p-cat"  th:text="${p.subcategoria}">Cat</div>
+            <div class="p-bottom">
+              <div class="p-price" th:text="${p.precio}">$0</div>

+<!DOCTYPE html>
+<html lang="es" xmlns:th="http://www.thymeleaf.org">
+<head>
+    <meta charset="UTF-8">
+    <title>Dream Zone - Registro</title>
+    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
+    <link rel="stylesheet" th:href="@{/css/style.css}">
+</head>
+<body>
+<div class="auth-screen active">
+    <div class="auth-left">
+        <div class="auth-brand">DREAM<span>ZONE</span></div>
+        <div class="auth-left-copy">© DREAM ZONE 2025</div>
+    </div>
+    <div class="auth-right">
+        <div class="auth-title">Crear Cuenta</div>
+
+        <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:5px;padding:9px 12px;font-size:12px;color:#b91c1c;text-align:center;margin-bottom:12px;"
+             th:if="${error}" th:text="${error}"></div>
+
+        <form method="post" action="/register">
+            <div class="f-group">
+                <label class="f-label">Nombre completo</label>
+                <input class="f-input" type="text" name="nombre" placeholder="Tu nombre completo" required>
+            </div>
+            <div class="f-group">
+                <label class="f-label">Correo electrónico</label>
+                <input class="f-input" type="email" name="email" placeholder="correo@ejemplo.com" required>
+            </div>
+            <div class="f-group">
+                <label class="f-label">Contraseña</label>
+                <input class="f-input" type="password" name="password" placeholder="Mínimo 6 caracteres" required>
+            </div>
+            <div class="f-group">
+                <label class="f-label">Confirmar contraseña</label>
+                <input class="f-input" type="password" name="password2" placeholder="Repite la contraseña" required>
+            </div>
+            <button class="big-btn orange" type="submit">REGISTRARME</button>
+        </form>
+        <div class="auth-foot">¿Ya tienes cuenta? <a href="/login" class="lnk">Inicia sesión</a></div>
+        <div class="auth-foot" style="margin-top:6px;"><a href="/" class="lnk">← Volver al inicio</a></div>
+    </div>
+</div>
+</body>
+</html>

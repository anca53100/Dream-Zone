@@ -0,0 +1,113 @@
+*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
+html,body{height:100%;font-family:'Barlow',sans-serif;}
+:root{
+    --bg:#0f1520;--navy:#111827;--panel:#1a2236;
+    --border:#1e2a3a;--accent:#f5a623;--blue:#3b82f6;
+    --text:#fff;--muted:#8492a6;--price:#3b82f6;
+}
+.screen{display:none;}
+.screen.active{display:flex;flex-direction:column;min-height:100vh;}
+.auth-screen{display:none;}
+.auth-screen.active{display:grid;grid-template-columns:1fr 1fr;min-height:100vh;}
+
+/* NAVBAR */
+.navbar{background:var(--navy);display:flex;align-items:center;padding:0 28px;height:54px;flex-shrink:0;}
+.brand{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:900;color:#fff;letter-spacing:1px;text-transform:uppercase;cursor:pointer;white-space:nowrap;margin-right:32px;}
+.brand span{color:var(--accent);}
+.nav-links{display:flex;gap:2px;flex:1;}
+.nav-link{background:none;border:none;font-family:'Barlow',sans-serif;font-size:14px;font-weight:500;color:#c0c8d8;padding:6px 16px;cursor:pointer;transition:color .15s;border-bottom:2px solid transparent;}
+.nav-link:hover{color:#fff;}
+.nav-link.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600;}
+.nav-icons{display:flex;gap:10px;}
+.nav-icon{background:none;border:none;color:#c0c8d8;font-size:18px;cursor:pointer;padding:4px;transition:color .15s;position:relative;display:flex;align-items:center;}
+.nav-icon:hover{color:#fff;}
+.cart-badge{position:absolute;top:-4px;right:-4px;background:var(--accent);color:#000;font-size:9px;font-weight:800;width:15px;height:15px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
+
+/* SEARCH */
+.search-bar{background:var(--bg);border-bottom:1px solid var(--border);padding:10px 28px;display:none;}
+.search-bar.open{display:block;}
+.search-inner{display:flex;align-items:center;gap:8px;background:var(--panel);border:1.5px solid var(--accent);border-radius:6px;padding:0 14px;max-width:540px;}
+.search-inner input{flex:1;background:none;border:none;outline:none;color:#fff;font-size:14px;padding:10px 0;font-family:'Barlow',sans-serif;}
+.search-inner input::placeholder{color:var(--muted);}
+.search-inner button{background:none;border:none;color:var(--muted);font-size:16px;cursor:pointer;}
+.search-inner button:hover{color:#fff;}
+
+/* MAIN */
+.main{flex:1;background:var(--bg);padding:20px 28px 36px;}
+.section-title{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:#fff;margin-bottom:12px;}
+
+/* CAROUSEL */
+.carousel-outer{position:relative;margin-bottom:28px;}
+.carousel-track{display:flex;gap:14px;overflow:hidden;}
+.c-arrow{position:absolute;top:50%;transform:translateY(-50%);background:rgba(17,24,39,.8);border:1px solid var(--border);color:#fff;font-size:22px;font-weight:700;width:32px;height:32px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;transition:background .15s;}
+.c-arrow:hover{background:var(--border);}
+.c-arrow.prev{left:-16px;}
+.c-arrow.next{right:-16px;}
+
+/* PRODUCT CARD */
+.p-card{background:#fff;border:1px solid #d0d4de;border-radius:6px;overflow:hidden;cursor:pointer;transition:box-shadow .2s,transform .2s;flex-shrink:0;}
+.carousel-track .p-card{min-width:calc(20% - 12px);}
+.p-card:hover{box-shadow:0 4px 20px rgba(0,0,0,.3);transform:translateY(-2px);}
+.p-img-wrap{background:#c8cad4;aspect-ratio:1;display:flex;align-items:center;justify-content:center;position:relative;}
+.p-placeholder{width:48%;height:48%;opacity:.45;}
+.p-badge{position:absolute;top:6px;left:6px;background:#e53935;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:800;letter-spacing:1px;padding:2px 6px;border-radius:2px;}
+.p-info{padding:8px 10px 10px;}
+.p-name{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;color:#111;margin-bottom:1px;}
+.p-cat{font-size:10px;color:#888;margin-bottom:6px;}
+.p-bottom{display:flex;align-items:center;justify-content:space-between;}
+.p-price{font-size:13px;font-weight:700;color:var(--price);}
+.p-cart-btn{background:none;border:none;cursor:pointer;color:var(--price);font-size:16px;transition:transform .15s;padding:2px;display:flex;align-items:center;}
+.p-cart-btn:hover{transform:scale(1.2);}
+
+/* GRID */
+.grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
+.ver-todo-btn{background:none;border:none;font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;color:var(--accent);cursor:pointer;text-transform:uppercase;}
+.ver-todo-btn:hover{text-decoration:underline;}
+.products-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;}
+.products-grid .p-card{min-width:0;}
+.empty{grid-column:1/-1;text-align:center;padding:50px;color:var(--muted);font-size:14px;}
+
+/* FOOTER */
+.footer{background:var(--navy);display:flex;align-items:center;justify-content:space-between;padding:12px 28px;flex-shrink:0;}
+.footer .brand{font-size:18px;cursor:default;}
+.footer-copy{font-size:11px;color:var(--muted);}
+.footer-icons{display:flex;gap:10px;align-items:center;}
+
+/* AUTH */
+.auth-left{background:var(--navy);display:flex;flex-direction:column;justify-content:center;padding:60px 50px;position:relative;overflow:hidden;}
+.auth-left::after{content:'';position:absolute;bottom:-60px;left:-60px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(245,166,35,.07) 0%,transparent 70%);pointer-events:none;}
+.auth-brand{font-family:'Barlow Condensed',sans-serif;font-size:80px;font-weight:900;line-height:.88;text-transform:uppercase;color:#fff;}
+.auth-brand span{color:var(--accent);display:block;}
+.auth-left-copy{position:absolute;bottom:18px;left:50px;font-size:11px;color:var(--muted);letter-spacing:1px;}
+.auth-right{background:#fff;display:flex;flex-direction:column;justify-content:center;padding:54px 50px;}
+.auth-title{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:var(--accent);text-align:center;margin-bottom:26px;}
+.f-group{margin-bottom:14px;}
+.f-label{font-size:12px;color:#555;margin-bottom:5px;display:block;}
+.f-input{width:100%;padding:10px 12px;background:#eff1f5;border:1.5px solid #d2d6e0;border-radius:5px;outline:none;font-family:'Barlow',sans-serif;font-size:13px;color:#111;transition:border .15s;}
+.f-input:focus{border-color:var(--blue);background:#fff;}
+.f-input.err{border-color:#e53935;}
+.f-err{font-size:11px;color:#e53935;margin-top:3px;display:none;}
+.f-err.show{display:block;}
+.forgot-row{text-align:right;margin-top:4px;}
+.lnk{background:none;border:none;font-size:11px;color:var(--blue);cursor:pointer;font-family:'Barlow',sans-serif;}
+.lnk:hover{text-decoration:underline;}
+.big-btn{width:100%;padding:12px;margin-top:6px;background:var(--blue);border:none;border-radius:5px;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:3px;cursor:pointer;transition:background .15s;}
+.big-btn:hover{background:#2563eb;}
+.big-btn.orange{background:var(--accent);color:#000;}
+.big-btn.orange:hover{background:#d9911a;}
+.divider{display:flex;align-items:center;gap:10px;margin:16px 0;}
+.divider::before,.divider::after{content:'';flex:1;height:1px;background:#d2d6e0;}
+.divider span{font-size:11px;color:#aaa;}
+.social-row{display:flex;gap:10px;}
+.social-btn{flex:1;padding:9px;background:#f0f2f6;border:1.5px solid #d2d6e0;border-radius:5px;font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;color:#444;cursor:pointer;transition:background .15s;}
+.social-btn:hover{background:#e2e5ec;}
+.auth-foot{text-align:center;margin-top:14px;font-size:12px;color:#777;}
+.auth-foot .lnk{font-size:12px;font-weight:600;}
+.sbox{background:#ecfdf5;border:1px solid #6ee7b7;border-radius:5px;padding:9px 12px;font-size:12px;color:#065f46;text-align:center;margin-bottom:12px;display:none;}
+.sbox.show{display:block;}
+
+/* TOAST */
+.toast{position:fixed;bottom:24px;right:24px;background:var(--navy);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:7px;padding:11px 16px;font-size:13px;color:#fff;z-index:9999;transform:translateX(140%);transition:transform .3s ease;max-width:280px;}
+.toast.show{transform:translateX(0);}
+.toast.red{border-left-color:#e53935;}
+.toast.green{border-left-color:#22c55e;}
